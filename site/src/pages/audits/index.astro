---
import Base from "../../layouts/Base.astro";

const audits = [
  {
    slug: "p-multi-adversary",
    title: "Cross-family vs intra-Claude — the four-adversary experiment",
    date: "2026-05-17",
    verdict: "Methodology pivot",
    summary: "Ran four adversaries (Opus 4.7 + Sonnet 4.6 + Haiku 4.5 + Qwen3-coder) against the v0.3.4 diff. H1 (cross-family additive): REFUTED — Qwen produced zero substantive findings the Claudes hadn't raised. H2 (intra-family disagreement): CONFIRMED — three different verdicts on the same input, and the most novel finding (F-OPUS-004 Unicode bypass) came from intra-Claude diversity. v0.4.0 ships what the data points at: opus + sonnet + haiku is now the default panel.",
    findings: { critical: 1, warning: 4, suggestion: 6 },
  },
  {
    slug: "p-v034-audit",
    title: "The convergence test",
    date: "2026-05-14",
    verdict: "Escalate",
    summary: "Third audit. v0.3.4 shipped the architectural pivot P-v033's adversary prescribed. Test result: pivoted but not converged — the LCD-as-truth-oracle defect family persists in the new primitive, AND the adversary surfaced a Critical that's been latent across all three audit cycles. The lens trio's diff-bounded scope is the structural blind spot adversarial review exists to fill.",
    findings: { critical: 2, warning: 6, suggestion: 15 },
  },
  {
    slug: "p-v033-audit",
    title: "Does the methodology converge?",
    date: "2026-05-13 (evening)",
    verdict: "Escalate",
    summary: "Second self-audit. v0.3.3 fixed everything P-v032-audit surfaced — but the adversary identified a structural recursion: each fix is a narrower version of the same primitive. The methodology is not converging on a fixed point yet. v0.3.4 must change the primitive.",
    findings: { critical: 1, warning: 9, suggestion: 11 },
  },
  {
    slug: "p-v032-audit",
    title: "Tribunal reviews v0.3.2",
    date: "2026-05-13",
    verdict: "Escalate",
    summary: "First time Tribunal audited its own release. Trio caught surface defects; adversary caught a Critical correctness defect every cooperative lens missed (F-NEW-301, batched-tx atomicity). v0.3.3 fixes shipped same day.",
    findings: { critical: 3, warning: 12, suggestion: 15 },
  },
];
---
<Base title="Audits" description="Public audit reports settled on Burnt XION testnet.">
  <section class="border-b border-ink-800/80">
    <div class="max-w-4xl mx-auto px-6 pt-20 pb-12">
      <p class="text-xs uppercase tracking-[0.2em] text-verdict-adversary font-mono mb-6">Audits</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold text-ink-50 tracking-tight leading-[1.1]">
        Every audit is on the public record.
      </h1>
      <p class="mt-6 text-lg text-ink-300 max-w-2xl leading-relaxed">
        Each report is signed by the filing agent's keypair and settled on <code class="hash bg-ink-800/60 px-1.5 py-0.5 rounded">xion-testnet-2</code>.
        Four self-audit cycles plus the four-adversary experiment that motivated the v0.4 panel reshape. The
        adversary's running thesis across the v0.3.x audits (F-NEW-403, F-NEW-505): the methodology was converging on defect
        <em>shapes</em> but not defect <em>families</em>. The
        <a href="/docs/convergence" class="text-verdict-adversary underline underline-offset-2 hover:text-verdict-approve">convergence</a>
        extension (v0.4) addressed families through multi-round loops; the
        <a href="/docs/temporal-lens" class="text-verdict-adversary underline underline-offset-2 hover:text-verdict-approve">temporal lens</a>
        (v0.5) closes the longitudinal-composition gap the per-component lenses systematically underweight.
      </p>
    </div>
  </section>

  <section>
    <div class="max-w-4xl mx-auto px-6 py-16">
      <ul class="space-y-4">
        {audits.map((a) => (
          <li>
            <a href={`/audits/${a.slug}`} class="block rounded-xl border border-ink-700/60 bg-ink-900/40 p-6 hover:border-verdict-adversary/40 hover:bg-ink-900/60 transition-colors group">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="font-display text-xl font-semibold text-ink-50 group-hover:text-verdict-adversary transition-colors">
                  {a.title}
                </h2>
                <span class="font-mono text-xs text-ink-400">{a.date}</span>
              </div>
              <p class="mt-2 text-ink-300 leading-relaxed">{a.summary}</p>
              <div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-mono">
                <span class="px-2 py-0.5 rounded border verdict-escalate uppercase tracking-wider">{a.verdict}</span>
                <span class="text-verdict-critical">{a.findings.critical} critical</span>
                <span class="text-verdict-warn">{a.findings.warning} warning</span>
                <span class="text-ink-400">{a.findings.suggestion} suggestion</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
