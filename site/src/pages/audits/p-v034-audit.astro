---
import Base from "../../layouts/Base.astro";

const reports = import.meta.glob<{ Content: any }>(
  "../../../_content/reports/P-v034-audit/*.md",
  { eager: true }
);

const order = ["SYNTHESIS", "reviewer-arch", "reviewer-sec", "reviewer-perf", "adversary"];
const labels: Record<string, { tab: string; accent: string }> = {
  SYNTHESIS:       { tab: "Synthesis",    accent: "verdict-adversary" },
  "reviewer-arch": { tab: "Architecture", accent: "verdict-approve" },
  "reviewer-sec":  { tab: "Security",     accent: "verdict-critical" },
  "reviewer-perf": { tab: "Performance",  accent: "verdict-approve" },
  adversary:       { tab: "Adversary",    accent: "verdict-critical" },
};

const sections: { id: string; Content: any; tab: string; accent: string }[] = [];
for (const path in reports) {
  const m = path.match(/\/([^/]+)\.md$/);
  if (!m) continue;
  const id = m[1];
  const meta = labels[id];
  if (!meta) continue;
  sections.push({ id, Content: (reports[path] as any).Content, tab: meta.tab, accent: meta.accent });
}
sections.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));

const contractAddress = "xion1rw526nsectccl335slusux4szcpk77h23y8tyg5g9drhkhnhhnss9cps84";
const chainID = "xion-testnet-2";
const commitTx = "637BE806A0C1EAF806E18E600494BBFEA6C168663EC64C2E1A31FF6382723A2E";
const resolveTx = "94CBE524124567D8A21627B28D6677C4FBBCEE35B5865C1814F1699974736124";
const explorerBase = "https://explorer.burnt.com/xion-testnet-2/tx";

const stats = [
  { k: "Findings filed",   v: "23",       foot: "Third self-audit cycle." },
  { k: "Critical",         v: "2",        foot: "F-SEC-401 (recovery LCD trust) + F-NEW-501 (3-cycle latent on success path)." },
  { k: "Warnings",         v: "6",        foot: "Trio + adversary cross-cycle findings." },
  { k: "Suggestions",      v: "15",       foot: "Polish + carry-forwards." },
  { k: "Settle time",      v: "14s",      foot: "Single commit + resolve batch on xion-testnet-2." },
  { k: "Convergence",      v: "#2",       foot: "Pivoted but not converged — defect family persists in new primitive." },
];

// Cumulative leaderboard across THREE audits, post-P-v034 settlement.
const reputation = [
  { rank: 1, agent: "reviewer-arch",   balance: 260, tp: 23 },
  { rank: 2, agent: "reviewer-sec",    balance: 248, tp: 25 },
  { rank: 3, agent: "adversary-alpha", balance: 240, tp: 15 },
  { rank: 4, agent: "reviewer-perf",   balance: 160, tp: 12 },
  { rank: 5, agent: "pm-alpha",        balance: 100, tp:  0 },
];
---
<Base title="Audit · P-v034-audit" description="The convergence test. v0.3.4 pivoted away from regex-on-error-text — but a Critical that's been latent across three audit cycles surfaced.">
  <section class="border-b border-ink-800/80 bg-grid">
    <div class="max-w-6xl mx-auto px-6 pt-16 pb-12">
      <p class="text-xs uppercase tracking-[0.2em] text-verdict-adversary font-mono mb-5">
        Case study · 2026-05-14 (the convergence test)
      </p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold text-ink-50 tracking-tight leading-[1.1]">
        Pivoted but not converged.
      </h1>
      <p class="mt-6 text-lg text-ink-300 max-w-3xl leading-relaxed">
        v0.3.4 shipped the architectural pivot P-v033-audit's adversary prescribed. This audit tested whether the
        pivot actually broke the recursion. <strong class="text-ink-100">Empirical answer: outcome #2.</strong>
        The methodology converged on the specific defect <em>shape</em> (regex grammar narrowness) but the LCD-as-truth-oracle
        defect <em>family</em> persists in the new primitive — and a Critical the trio had missed across THREE cycles surfaced
        when the adversary widened scope outside the diff.
      </p>

      <div class="mt-10 rounded-xl border border-ink-700 bg-ink-900/60 p-5 grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-3 text-sm">
        <div>
          <p class="text-ink-400 text-xs uppercase tracking-[0.16em] font-mono">Plan ID</p>
          <p class="hash mt-1">P-v034-audit</p>
        </div>
        <div>
          <p class="text-ink-400 text-xs uppercase tracking-[0.16em] font-mono">Chain</p>
          <p class="hash mt-1">{chainID}</p>
        </div>
        <div>
          <p class="text-ink-400 text-xs uppercase tracking-[0.16em] font-mono">Contract</p>
          <p class="hash mt-1">{contractAddress}</p>
        </div>
        <div>
          <p class="text-ink-400 text-xs uppercase tracking-[0.16em] font-mono">Verdict</p>
          <p class="mt-1 inline-flex items-center gap-2 px-2 py-0.5 rounded border verdict-escalate text-xs uppercase tracking-wider font-mono">
            Escalate
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-ink-800/80">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
        {stats.map((s) => (
          <div>
            <p class="text-xs uppercase tracking-[0.16em] text-ink-400 font-mono">{s.k}</p>
            <p class="mt-2 font-display text-3xl text-ink-50 font-semibold">{s.v}</p>
            <p class="mt-1 text-xs text-ink-400 leading-snug">{s.foot}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HEADLINE CALLOUT -->
  <section class="border-b border-ink-800/80">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <div class="rounded-xl border border-verdict-critical/40 bg-verdict-critical/5 p-7 sm:p-10">
        <p class="text-xs uppercase tracking-[0.2em] text-verdict-critical font-mono mb-4">Three-cycle latent defect</p>
        <h2 class="font-display text-2xl sm:text-3xl font-semibold text-ink-50 tracking-tight leading-snug">
          F-NEW-501: silent-suppression on the success path.
        </h2>
        <p class="mt-5 text-ink-200 max-w-3xl leading-relaxed">
          The hostile-LCD silent-suppression vulnerability that the security reviewer found on the
          <em>recovery</em> path also exists on the <em>success</em> path. A hostile LCD that lies on the initial
          preflight causes <code class="hash bg-ink-800/60 px-1.5 py-0.5 rounded">commits</code> to filter empty;
          <code class="hash bg-ink-800/60 px-1.5 py-0.5 rounded">submitCommitBatch</code> never runs;
          <code class="hash bg-ink-800/60 px-1.5 py-0.5 rounded">SyncPlan</code> returns <code class="hash bg-ink-800/60 px-1.5 py-0.5 rounded">FindingsSent=0</code> with nil error.
          <strong class="text-ink-50">Observationally identical to a normal idempotent re-sync.</strong>
        </p>
        <p class="mt-4 text-ink-200 max-w-3xl leading-relaxed">
          This has been exploitable since v0.3.2 — across THREE audit cycles — because each cycle's lens reviewers
          only audit the new code in that diff. The success-path preflight is older code (added v0.3.2, unchanged
          v0.3.3, unchanged v0.3.4). <strong class="text-ink-50">The lens trio's diff-bounded scope is the structural blind spot the adversary stage exists to fill.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- CONVERGENCE THEORY -->
  <section class="border-b border-ink-800/80">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <div class="rounded-xl border border-verdict-adversary/30 bg-verdict-adversary/5 p-7 sm:p-10">
        <p class="text-xs uppercase tracking-[0.2em] text-verdict-adversary font-mono mb-4">Convergence theory</p>
        <h2 class="font-display text-2xl sm:text-3xl font-semibold text-ink-50 tracking-tight leading-snug">
          A methodology can converge on a defect shape without converging on its family.
        </h2>
        <p class="mt-5 text-ink-200 max-w-3xl leading-relaxed">
          Across three cycles, the specific defect SHAPES (regex grammar, identifier character set, structured-query
          trust posture) keep getting fixed. But the underlying FAMILY (LCD-as-truth-oracle) keeps generating new shapes.
          v0.3.5 must search by family.
        </p>
        <p class="mt-4 text-ink-200 max-w-3xl leading-relaxed">
          The adversary's prescription: <strong class="text-ink-50">don't cut v0.3.5 as a patch release.</strong> Start v0.4
          with ABCI-proof reads as the architectural primitive. That closes the entire LCD-trust family by making
          the LCD untrustable infrastructure — its responses get verified against signed validator-set commitments.
          Future audits can't find another instance of this family because there are no instances.
        </p>
        <p class="mt-4 text-ink-300 max-w-3xl leading-relaxed text-sm">
          See <a href="/docs/convergence" class="text-verdict-adversary underline underline-offset-2 hover:text-verdict-approve">the convergence doc</a> for the multi-round loop spec.
        </p>
      </div>
    </div>
  </section>

  <!-- SEVERITY TRAJECTORY -->
  <section class="border-b border-ink-800/80">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <h2 class="font-display text-2xl font-semibold text-ink-50 tracking-tight mb-2">Severity trajectory across audits</h2>
      <p class="text-ink-300 text-sm max-w-2xl mb-6">
        Warning surface is reducing (12 → 9 → 6 across three cycles), which is real convergence on the cooperative-lens
        coverage. Critical count is non-monotonic because the adversary keeps surfacing latent defects in older code —
        F-NEW-301 (v0.3.2), F-NEW-403 (v0.3.3), F-NEW-501 (v0.3.4, 3-cycle latent). That's per-shape convergence with
        per-family non-convergence.
      </p>
      <div class="overflow-x-auto rounded-xl border border-ink-700 bg-ink-900/40">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ink-700 text-ink-300">
              <th class="text-left px-5 py-3 font-mono uppercase text-xs tracking-wider">Audit</th>
              <th class="text-left px-5 py-3 font-mono uppercase text-xs tracking-wider">Diff</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">Critical</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">Warning</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">Suggestion</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">Total</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-ink-800">
              <td class="px-5 py-3 text-ink-100 font-medium"><a href="/audits/p-v032-audit" class="hover:text-verdict-adversary">P-v032-audit</a></td>
              <td class="px-5 py-3 text-ink-300 font-mono text-xs">v0.3.2</td>
              <td class="px-5 py-3 text-right text-verdict-critical font-mono">3</td>
              <td class="px-5 py-3 text-right text-verdict-warn font-mono">12</td>
              <td class="px-5 py-3 text-right text-ink-400 font-mono">15</td>
              <td class="px-5 py-3 text-right text-ink-100 font-mono">30</td>
            </tr>
            <tr class="border-b border-ink-800">
              <td class="px-5 py-3 text-ink-100 font-medium"><a href="/audits/p-v033-audit" class="hover:text-verdict-adversary">P-v033-audit</a></td>
              <td class="px-5 py-3 text-ink-300 font-mono text-xs">v0.3.3</td>
              <td class="px-5 py-3 text-right text-verdict-critical font-mono">1</td>
              <td class="px-5 py-3 text-right text-verdict-warn font-mono">9</td>
              <td class="px-5 py-3 text-right text-ink-400 font-mono">11</td>
              <td class="px-5 py-3 text-right text-ink-100 font-mono">21</td>
            </tr>
            <tr class="border-b border-ink-800 last:border-0">
              <td class="px-5 py-3 text-ink-100 font-medium">P-v034-audit</td>
              <td class="px-5 py-3 text-ink-300 font-mono text-xs">v0.3.4</td>
              <td class="px-5 py-3 text-right text-verdict-critical font-mono">2</td>
              <td class="px-5 py-3 text-right text-verdict-warn font-mono">6</td>
              <td class="px-5 py-3 text-right text-ink-400 font-mono">15</td>
              <td class="px-5 py-3 text-right text-ink-100 font-mono">23</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- REPUTATION LEADERBOARD -->
  <section class="border-b border-ink-800/80">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <div class="flex items-baseline justify-between gap-4 mb-6">
        <div>
          <h2 class="font-display text-2xl font-semibold text-ink-50 tracking-tight">Cumulative on-chain reputation</h2>
          <p class="mt-2 text-ink-300 text-sm max-w-2xl">
            Three audits in. reviewer-sec moved to #2 by filing the Critical (F-SEC-401) plus 8 other findings in this cycle.
            adversary-alpha is third by count but keeps the highest per-finding stake density — every cycle the adversary
            files 5–7 findings concentrated in Critical+Warning.
          </p>
        </div>
        <a href="/leaderboard" class="text-sm text-verdict-adversary hover:text-verdict-approve font-mono">live leaderboard →</a>
      </div>
      <div class="overflow-x-auto rounded-xl border border-ink-700 bg-ink-900/40">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ink-700 text-ink-300">
              <th class="text-left px-5 py-3 font-mono uppercase text-xs tracking-wider">Rank</th>
              <th class="text-left px-5 py-3 font-mono uppercase text-xs tracking-wider">Agent</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">Balance</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">TP</th>
              <th class="text-right px-5 py-3 font-mono uppercase text-xs tracking-wider">FP</th>
            </tr>
          </thead>
          <tbody>
            {reputation.map((r) => (
              <tr class="border-b border-ink-800 last:border-0">
                <td class="px-5 py-3 text-ink-300 font-mono">{r.rank}</td>
                <td class="px-5 py-3 font-medium text-ink-50">{r.agent}</td>
                <td class="px-5 py-3 text-right text-ink-100 font-mono">{r.balance}</td>
                <td class="px-5 py-3 text-right text-verdict-approve font-mono">{r.tp}</td>
                <td class="px-5 py-3 text-right text-ink-400 font-mono">0</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-6 grid sm:grid-cols-2 gap-4 text-xs text-ink-400 font-mono">
        <a href={`${explorerBase}/${commitTx}`} target="_blank" rel="noopener" class="flex items-start gap-2 hover:text-ink-100">
          <span class="text-ink-500 shrink-0">commit_tx ↗</span>
          <span class="hash">{commitTx}</span>
        </a>
        <a href={`${explorerBase}/${resolveTx}`} target="_blank" rel="noopener" class="flex items-start gap-2 hover:text-ink-100">
          <span class="text-ink-500 shrink-0">resolve_tx ↗</span>
          <span class="hash">{resolveTx}</span>
        </a>
      </div>
    </div>
  </section>

  <!-- TABBED REPORTS -->
  <section>
    <div class="max-w-6xl mx-auto px-6 py-14">
      <div class="mb-8">
        <h2 class="font-display text-2xl font-semibold text-ink-50 tracking-tight">The five reports</h2>
        <p class="mt-2 text-ink-300 max-w-2xl">
          Synthesis first, then each lens reviewer, then the adversary. Every report was filed verbatim,
          signed by the filing agent, and settled on-chain.
        </p>
      </div>

      <div role="tablist" aria-label="Audit reports" class="flex flex-wrap gap-1 border-b border-ink-800 mb-8">
        {sections.map((s, i) => (
          <button
            type="button"
            role="tab"
            data-tab-target={s.id}
            aria-selected={i === 0 ? "true" : "false"}
            class={`px-4 py-2 -mb-px border-b-2 text-sm font-medium transition-colors ${
              i === 0
                ? "border-verdict-adversary text-ink-50"
                : "border-transparent text-ink-300 hover:text-ink-100"
            }`}
          >
            {s.tab}
          </button>
        ))}
      </div>

      {sections.map((s, i) => (
        <article
          data-tab-panel={s.id}
          class={`prose-tribunal ${i === 0 ? "" : "hidden"}`}
        >
          <s.Content />
        </article>
      ))}
    </div>
  </section>
</Base>

<script is:inline>
  (() => {
    const tabs = document.querySelectorAll("[data-tab-target]");
    const panels = document.querySelectorAll("[data-tab-panel]");
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.getAttribute("data-tab-target");
        tabs.forEach((t) => {
          const active = t === tab;
          t.setAttribute("aria-selected", active ? "true" : "false");
          t.classList.toggle("border-verdict-adversary", active);
          t.classList.toggle("text-ink-50", active);
          t.classList.toggle("border-transparent", !active);
          t.classList.toggle("text-ink-300", !active);
        });
        panels.forEach((p) => {
          p.classList.toggle("hidden", p.getAttribute("data-tab-panel") !== target);
        });
      });
    });
  })();
</script>
