---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Adversarial code review with on-chain reputation. Three lens reviewers + one adversary + signed findings settled on a CosmWasm contract.",
} = Astro.props;

const titleSuffix = title === "Tribunal" ? "Tribunal" : `${title} — Tribunal`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0c" />
    <meta property="og:title" content={titleSuffix} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{titleSuffix}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
