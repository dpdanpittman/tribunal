# Go build output
/tribunal
/bin/
*.test
*.out
*.prof

# Go module cache (only if vendored — we don't vendor by default)
/vendor/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Tribunal local state. Most of this dir is per-developer working state,
# but committed review reports (lens reports, adversary reports,
# synthesis) live under .tribunal/reports/ and are tracked.
/.tribunal/*
!/.tribunal/reports/
examples/*/.tribunal/local/

# Contract build artifacts
contracts/*/target/
contracts/*/artifacts/

# Secrets (the contract operator key, chain config)
~/.tribunal/
